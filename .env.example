# =================================================================
# Dental Advance — Variables de Entorno
# =================================================================
# Copia este archivo como .env.local y completa los valores reales.
# NUNCA subas .env.local a Git (ya está en .gitignore).
# =================================================================


# ── Resend — Email transaccional ─────────────────────────────────
# Obtener en: https://resend.com → API Keys
# Plan gratuito: 3,000 emails/mes
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email donde llegan los mensajes del formulario de contacto
CONTACT_EMAIL=dentaladvancegc@gmail.com

# Nombre del negocio (aparece en el asunto de los emails)
BUSINESS_NAME=Dental Advance

# Email remitente de Resend
# Durante pruebas: onboarding@resend.dev (limitado a tu propio email)
# En producción: usar un dominio verificado en Resend, p.ej. noreply@dentaladvance.com
FROM_EMAIL=onboarding@resend.dev


# ── URL del sitio ─────────────────────────────────────────────────
SITE_URL=https://dentaladvance.com


# ── Google Analytics 4 (opcional) ────────────────────────────────
# Obtener en: https://analytics.google.com
# Agregar al Layout.astro dentro del cookie banner
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX


# ── Google Tag Manager (opcional) ────────────────────────────────
# Obtener en: https://tagmanager.google.com
PUBLIC_GTM_ID=GTM-XXXXXXX


# ── Meta Pixel — Facebook Ads (opcional) ─────────────────────────
# Obtener en: https://business.facebook.com → Events Manager
PUBLIC_META_PIXEL_ID=


# ── Google Maps API Key (opcional) ───────────────────────────────
# Solo necesaria si usas Maps JavaScript API o Places API.
# El embed actual (iframe) NO requiere API key.
# Obtener en: https://console.cloud.google.com → APIs & Services
PUBLIC_GOOGLE_MAPS_API_KEY=
