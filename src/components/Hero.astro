---
import { site } from '../content/site.ts';
---

<section id="inicio" class="relative min-h-[88vh] sm:min-h-screen flex items-center overflow-hidden bg-dark-900">

  <!-- ── Fondo decorativo — sin imagen problemática ── -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <!-- Glow dorado izquierda -->
    <div class="absolute -top-40 -left-40 w-[600px] h-[600px] bg-gold-500/8 rounded-full blur-[120px]"></div>
    <!-- Glow dorado derecha -->
    <div class="absolute -bottom-20 right-0 w-[500px] h-[500px] bg-gold-500/6 rounded-full blur-[100px]"></div>
    <!-- Grid sutil -->
    <div class="absolute inset-0 opacity-[0.025]"
      style="background-image: linear-gradient(to right, rgba(200,150,12,0.5) 1px, transparent 1px), linear-gradient(to bottom, rgba(200,150,12,0.5) 1px, transparent 1px); background-size: 64px 64px;">
    </div>
  </div>

  <!-- ── Decoración derecha — anillos concéntricos ── -->
  <div class="absolute right-[-120px] top-1/2 -translate-y-1/2 w-[520px] h-[520px] pointer-events-none select-none hidden lg:block" aria-hidden="true">
    <div class="absolute inset-0 rounded-full border border-gold-500/10"></div>
    <div class="absolute inset-[60px] rounded-full border border-gold-500/12"></div>
    <div class="absolute inset-[120px] rounded-full border border-gold-500/15"></div>
    <div class="absolute inset-[180px] rounded-full bg-gold-500/5 rounded-full"></div>
  </div>

  <!-- ── Contenido ── -->
  <div class="relative w-full container-custom mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-36">
    <div class="max-w-xl lg:max-w-2xl">

      <!-- Eyebrow -->
      <div class="flex items-center gap-3 mb-6 animate-fade-in">
        <span class="w-8 h-px bg-gold-500/60" aria-hidden="true"></span>
        <span class="text-gold-400/80 text-xs font-semibold tracking-[0.22em] uppercase">{site.contact.address.city}, {site.contact.address.state}</span>
      </div>

      <!-- Headline -->
      <h1
        class="font-heading font-bold leading-[1.06] text-white mb-5 animate-fade-in-up"
        style="animation-delay: 0.08s; font-size: clamp(2.6rem, 6.5vw, 5rem); letter-spacing: -0.025em;"
      >
        Tu Sonrisa,<br>
        <span class="gold-text">Nuestra Especialidad.</span>
      </h1>

      <!-- Subtitle -->
      <p
        class="text-dark-300 text-base sm:text-lg max-w-md leading-relaxed mb-10 animate-fade-in-up"
        style="animation-delay: 0.18s"
      >
        Clínica dental con tecnología de vanguardia y atención
        personalizada en Cuauhtémoc, Chihuahua.
      </p>

      <!-- CTA — un solo botón principal -->
      <div class="flex flex-wrap items-center gap-4 animate-fade-in-up" style="animation-delay: 0.28s">
        <a
          href={`https://wa.me/${site.contact.whatsappNumber}?text=${site.wa.agendarCita}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-base"
          data-cta="hero-agendar"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Agendar Cita por WhatsApp
        </a>
        <a
          href="#servicios"
          class="text-dark-400 text-sm hover:text-gold-400 transition-colors duration-200"
          data-cta="hero-servicios"
        >
          Ver servicios →
        </a>
      </div>

    </div>
  </div>

  <!-- ── Trust strip — 3 ítems limpios ── -->
  <div class="absolute bottom-0 left-0 right-0 border-t border-white/8 bg-dark-900/60 backdrop-blur-sm">
    <div class="container-custom mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-3 divide-x divide-white/8">

        <div class="flex items-center gap-3 py-4 pr-4 sm:pr-8">
          <div class="w-8 h-8 rounded-lg bg-gold-500/15 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gold-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M12 2C9.5 2 7 3.5 7 6c0 2-1 3-2 5s-1 5 0 7c.7 1.3 1.5 2 2.5 2s2-1.5 2.5-3c.3-.8.7-1 1-1h2c.3 0 .7.2 1 1 .5 1.5 1.5 3 2.5 3s1.8-.7 2.5-2c1-2 1-5 0-7s-2-3-2-5c0-2.5-2.5-4-5-4z"/>
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-white text-xs sm:text-sm font-semibold leading-tight truncate">8+ Especialidades</p>
            <p class="text-white/40 text-xs hidden sm:block">Bajo un mismo techo</p>
          </div>
        </div>

        <div class="flex items-center gap-3 py-4 px-4 sm:px-8">
          <div class="w-8 h-8 rounded-lg bg-gold-500/15 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gold-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-white text-xs sm:text-sm font-semibold leading-tight truncate">{site.hours.compact}</p>
            <p class="text-white/40 text-xs hidden sm:block">Doble turno</p>
          </div>
        </div>

        <div class="flex items-center gap-3 py-4 pl-4 sm:pl-8">
          <div class="w-8 h-8 rounded-lg bg-gold-500/15 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gold-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-white text-xs sm:text-sm font-semibold leading-tight truncate">{site.contact.address.colony}</p>
            <p class="text-white/40 text-xs hidden sm:block truncate">{site.contact.address.street}</p>
          </div>
        </div>

      </div>
    </div>
  </div>

</section>
