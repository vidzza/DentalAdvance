---
import { site } from '../content/site.ts';
const navLinks = [
  { href: '#inicio',      label: 'Inicio' },
  { href: '#servicios',   label: 'Servicios' },
  { href: '#nosotros',    label: 'Nosotros' },
  { href: '#testimonios', label: 'Testimonios' },
  { href: '#faq',         label: 'FAQ' },
  { href: '#contacto',    label: 'Contacto' },
];
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="container-custom mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">

      <!-- Logo -->
      <a href="#inicio" class="flex items-center gap-3 group" aria-label="Dental Advance - Inicio">
        <div class="w-11 h-11 rounded-full overflow-hidden flex-shrink-0 ring-2 ring-gold-500/30 transition-transform duration-300 group-hover:scale-105">
          <img
            src={`${import.meta.env.BASE_URL}images/logo.png`}
            alt="Dental Advance"
            width="44"
            height="44"
            class="w-full h-full object-cover scale-110"
          />
        </div>
        <div class="hidden sm:block">
          <span class="header-logo-text block text-base font-heading font-bold leading-tight text-white transition-colors duration-300">
            Dental Advance
          </span>
          <span class="header-logo-sub block text-[11px] text-white/60 transition-colors duration-300">
            Cd. Cuauhtémoc, Chih.
          </span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Navegación principal">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="header-nav-link px-4 py-2 text-sm font-medium text-white/80 rounded-lg transition-all duration-200 hover:text-gold-400"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Desktop CTA + Mobile Toggle -->
      <div class="flex items-center gap-3">
        <a
          href={`https://wa.me/${site.contact.whatsappNumber}?text=${site.wa.agendarCita}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary !text-sm !px-5 !py-2.5 hidden sm:inline-flex"
          data-cta="header-agendar"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Agendar Cita
        </a>

        <!-- Hamburger — always clearly visible -->
        <button
          id="mobile-menu-btn"
          type="button"
          class="lg:hidden flex items-center justify-center w-11 h-11 rounded-xl bg-white/15 backdrop-blur-sm border border-white/20 text-white transition-all duration-200 hover:bg-white/25"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="4" y1="7" x2="20" y2="7"></line>
            <line x1="4" y1="12" x2="20" y2="12"></line>
            <line x1="4" y1="17" x2="20" y2="17"></line>
          </svg>
          <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu — full-screen overlay, independent of header -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] bg-dark-900 flex flex-col lg:hidden"
  style="display: none;"
  aria-hidden="true"
>
  <!-- Top bar inside overlay -->
  <div class="flex items-center justify-between px-5 h-20 border-b border-white/8 flex-shrink-0">
    <a href="#inicio" class="flex items-center gap-3" aria-label="Dental Advance">
      <div class="w-10 h-10 rounded-full overflow-hidden ring-2 ring-gold-500/30">
        <img src={`${import.meta.env.BASE_URL}images/logo.png`} alt="" width="40" height="40" class="w-full h-full object-cover scale-110" aria-hidden="true" />
      </div>
      <span class="text-white font-heading font-bold text-base">Dental Advance</span>
    </a>
    <button
      id="mobile-menu-close"
      type="button"
      class="flex items-center justify-center w-11 h-11 rounded-xl bg-white/10 text-white hover:bg-white/20 transition-colors"
      aria-label="Cerrar menú"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Nav links -->
  <nav class="flex flex-col px-5 py-6 gap-1 flex-1 overflow-y-auto" aria-label="Navegación móvil">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="mobile-nav-link flex items-center justify-between px-4 py-4 text-lg font-medium text-white/80 rounded-xl hover:text-gold-400 hover:bg-white/6 transition-all duration-150 border-b border-white/5 last:border-0"
      >
        {link.label}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    ))}
  </nav>

  <!-- Bottom CTA -->
  <div class="px-5 pb-10 pt-4 border-t border-white/8 flex-shrink-0">
    <p class="text-white/40 text-xs text-center mb-4">{site.hours.compact}</p>
    <a
      href={`https://wa.me/${site.contact.whatsappNumber}?text=${site.wa.agendarCita}`}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-primary w-full justify-center text-base"
      data-cta="mobile-agendar"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Agendar Cita por WhatsApp
    </a>
  </div>
</div>

<script is:inline>
  const menuBtn    = document.getElementById('mobile-menu-btn');
  const menuClose  = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen   = document.getElementById('menu-icon-open');
  const iconClose  = document.getElementById('menu-icon-close');
  const header     = document.getElementById('header');

  function openMenu() {
    mobileMenu.style.display = 'flex';
    mobileMenu.setAttribute('aria-hidden', 'false');
    menuBtn.setAttribute('aria-expanded', 'true');
    iconOpen.classList.add('hidden');
    iconClose.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu.style.display = 'none';
    mobileMenu.setAttribute('aria-hidden', 'true');
    menuBtn.setAttribute('aria-expanded', 'false');
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
    document.body.style.overflow = '';
  }

  if (menuBtn) menuBtn.addEventListener('click', openMenu);
  if (menuClose) menuClose.addEventListener('click', closeMenu);

  // Close on nav link click
  if (mobileMenu) {
    mobileMenu.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  }

  // Close on Escape
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeMenu();
  });

  /* ── Scroll: transparent → solid header ── */
  function updateHeader() {
    if (!header) return;
    const scrolled = window.scrollY > 70;
    if (scrolled) {
      header.style.background = 'rgba(254,252,248,0.97)';
      header.style.backdropFilter = 'blur(12px)';
      header.style.boxShadow = '0 1px 0 rgba(30,41,59,0.08)';
      header.style.borderBottom = '1px solid rgba(226,232,240,0.7)';
      // Logo text
      header.querySelectorAll('.header-logo-text').forEach(el => { el.style.color = '#1e293b'; });
      header.querySelectorAll('.header-logo-sub').forEach(el => { el.style.color = '#64748b'; });
      // Nav links
      header.querySelectorAll('.header-nav-link').forEach(el => { el.style.color = '#475569'; });
      // Hamburger
      const btn = document.getElementById('mobile-menu-btn');
      if (btn) {
        btn.style.background = 'rgba(30,41,59,0.08)';
        btn.style.borderColor = 'rgba(30,41,59,0.15)';
        btn.style.color = '#1e293b';
      }
    } else {
      header.style.background = '';
      header.style.backdropFilter = '';
      header.style.boxShadow = '';
      header.style.borderBottom = '';
      header.querySelectorAll('.header-logo-text').forEach(el => { el.style.color = ''; });
      header.querySelectorAll('.header-logo-sub').forEach(el => { el.style.color = ''; });
      header.querySelectorAll('.header-nav-link').forEach(el => { el.style.color = ''; });
      const btn = document.getElementById('mobile-menu-btn');
      if (btn) {
        btn.style.background = '';
        btn.style.borderColor = '';
        btn.style.color = '';
      }
    }
  }

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();
</script>
