---
import { site } from '../content/site.ts';
const currentYear = new Date().getFullYear();
---

<footer class="bg-dark-900 text-dark-300">

  <div class="gold-line"></div>

  <!-- Main Footer -->
  <div class="container-custom mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-10">
    <div class="grid lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Brand Column — dominant (2 cols) -->
      <div class="lg:col-span-2">
        <a href="#inicio" class="inline-flex items-center gap-3 mb-5 group" aria-label="Dental Advance — Inicio">
          <img
            src={`${import.meta.env.BASE_URL}images/logo.png`}
            alt="Dental Advance"
            width="44"
            height="44"
            class="w-11 h-11 object-contain"
            loading="lazy"
          />
          <div>
            <span class="block text-lg font-heading font-bold text-white group-hover:text-gold-400 transition-colors leading-tight">
              Dental Advance
            </span>
            <span class="block text-xs text-dark-400">Cd. Cuauhtémoc, Chihuahua</span>
          </div>
        </a>

        <p class="text-sm leading-relaxed max-w-sm mb-6">
          Clínica dental de vanguardia en Cd. Cuauhtémoc, Chihuahua.
          Tecnología avanzada, trato humano. <em class="text-white/60 not-italic">Tu sonrisa es nuestra especialidad.</em>
        </p>

        <!-- Contact quick-access -->
        <div class="space-y-2.5 mb-7">
          <a href={`tel:${site.contact.phoneE164}`} class="inline-flex items-center gap-2.5 text-sm hover:text-gold-400 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gold-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            {site.contact.phoneLocal}
          </a>
          <a href={`mailto:${site.contact.email}`} class="inline-flex items-center gap-2.5 text-sm hover:text-gold-400 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gold-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            {site.contact.email}
          </a>
          <p class="inline-flex items-center gap-2.5 text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gold-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            {site.contact.address.street}, {site.contact.address.colony}
          </p>
        </div>

        <!-- Social -->
        <div class="flex gap-2.5">
          <a
            href={site.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-lg bg-dark-700/60 flex items-center justify-center hover:bg-gold-500 transition-colors group"
            aria-label="Facebook de Dental Advance"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-dark-400 group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a
            href={site.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-lg bg-dark-700/60 flex items-center justify-center hover:bg-gold-500 transition-colors group"
            aria-label="Instagram de Dental Advance"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-dark-400 group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-heading font-semibold text-sm uppercase tracking-wider mb-5">Navegación</h4>
        <ul class="space-y-2.5">
          <li><a href="#inicio" class="text-sm hover:text-gold-400 transition-colors">Inicio</a></li>
          <li><a href="#servicios" class="text-sm hover:text-gold-400 transition-colors">Servicios</a></li>
          <li><a href="#nosotros" class="text-sm hover:text-gold-400 transition-colors">Nosotros</a></li>
          <li><a href="#testimonios" class="text-sm hover:text-gold-400 transition-colors">Testimonios</a></li>
          <li><a href="#faq" class="text-sm hover:text-gold-400 transition-colors">Preguntas Frecuentes</a></li>
          <li><a href="#contacto" class="text-sm hover:text-gold-400 transition-colors">Contacto</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-white font-heading font-semibold text-sm uppercase tracking-wider mb-5">Servicios</h4>
        <ul class="space-y-2.5">
          <li><a href="#servicios" class="text-sm hover:text-gold-400 transition-colors">Odontología General</a></li>
          <li><a href="#servicios" class="text-sm hover:text-gold-400 transition-colors">Ortodoncia</a></li>
          <li><a href="#servicios" class="text-sm hover:text-gold-400 transition-colors">Implantes Dentales</a></li>
          <li><a href="#servicios" class="text-sm hover:text-gold-400 transition-colors">Estética Dental</a></li>
          <li><a href="#servicios" class="text-sm hover:text-gold-400 transition-colors">Endodoncia</a></li>
          <li><a href="#servicios" class="text-sm hover:text-gold-400 transition-colors">Odontopediatría</a></li>
          <li><a href="#servicios" class="text-sm hover:text-gold-400 transition-colors">Cirugía Oral</a></li>
          <li><a href="#servicios" class="text-sm hover:text-gold-400 transition-colors">Periodoncia</a></li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Divider -->
  <div class="border-t border-dark-700/40">
    <div class="container-custom mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-dark-500">
        <p>&copy; {currentYear} Dental Advance. Todos los derechos reservados.</p>
        <a href="/aviso-de-privacidad" class="hover:text-gold-400 transition-colors">
          Aviso de Privacidad
        </a>
      </div>
    </div>
  </div>

</footer>
