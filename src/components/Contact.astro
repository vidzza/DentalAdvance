---
import { site } from '../content/site.ts';
---

<section id="contacto" class="section-padding bg-ivory-50">
  <div class="container-custom mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-14 reveal">
      <span class="section-label justify-center">Contacto</span>
      <h2 class="text-4xl sm:text-5xl font-heading font-bold text-dark-800 leading-[1.08] mb-4">
        Estamos para
        <span class="gold-text">atenderte</span>
      </h2>
      <p class="text-dark-400 leading-relaxed">
        Contáctanos por el medio que prefieras o visítanos en nuestra clínica.
      </p>
    </div>

    <!-- Top grid: form (3/5) + info (2/5) -->
    <div class="grid lg:grid-cols-5 gap-8 mb-8">

      <!-- Contact Form -->
      <div class="lg:col-span-3 reveal-left">
        <div class="bg-white rounded-2xl p-6 sm:p-8 shadow-sm border border-dark-100/40 h-full">
          <h3 class="text-lg font-heading font-bold text-dark-800 mb-6">
            Envíanos un mensaje
          </h3>
          <form class="space-y-4" id="contact-form" novalidate data-wa={site.contact.whatsappNumber}>

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-xs font-semibold text-dark-600 uppercase tracking-wider mb-1.5">Nombre *</label>
                <input type="text" id="name" name="name" required placeholder="Tu nombre"
                  class="w-full px-4 py-3 rounded-xl border border-dark-200 bg-ivory-50 text-dark-800 placeholder-dark-300 text-sm transition-all duration-200 focus:border-gold-500 focus:ring-2 focus:ring-gold-500/20 focus:outline-none" />
              </div>
              <div>
                <label for="phone" class="block text-xs font-semibold text-dark-600 uppercase tracking-wider mb-1.5">Teléfono *</label>
                <input type="tel" id="phone" name="phone" required placeholder="625 000 0000"
                  class="w-full px-4 py-3 rounded-xl border border-dark-200 bg-ivory-50 text-dark-800 placeholder-dark-300 text-sm transition-all duration-200 focus:border-gold-500 focus:ring-2 focus:ring-gold-500/20 focus:outline-none" />
              </div>
            </div>

            <div>
              <label for="email" class="block text-xs font-semibold text-dark-600 uppercase tracking-wider mb-1.5">Correo electrónico</label>
              <input type="email" id="email" name="email" placeholder="tu@email.com"
                class="w-full px-4 py-3 rounded-xl border border-dark-200 bg-ivory-50 text-dark-800 placeholder-dark-300 text-sm transition-all duration-200 focus:border-gold-500 focus:ring-2 focus:ring-gold-500/20 focus:outline-none" />
            </div>

            <div>
              <label for="service" class="block text-xs font-semibold text-dark-600 uppercase tracking-wider mb-1.5">Servicio de interés</label>
              <select id="service" name="service"
                class="w-full px-4 py-3 rounded-xl border border-dark-200 bg-ivory-50 text-dark-800 text-sm transition-all duration-200 focus:border-gold-500 focus:ring-2 focus:ring-gold-500/20 focus:outline-none appearance-none"
                style="background-image: url('data:image/svg+xml;charset=US-ASCII,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2220%22 height=%2220%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%23737373%22 stroke-width=%222%22><polyline points=%226 9 12 15 18 9%22/></svg>'); background-repeat: no-repeat; background-position: right 12px center; background-size: 16px;">
                <option value="">Selecciona un servicio</option>
                {site.serviceOptions.map(opt => (
                  <option value={opt.value}>{opt.label}</option>
                ))}
              </select>
            </div>

            <div>
              <label for="message" class="block text-xs font-semibold text-dark-600 uppercase tracking-wider mb-1.5">Mensaje</label>
              <textarea id="message" name="message" rows="3" placeholder="Cuéntanos cómo podemos ayudarte..."
                class="w-full px-4 py-3 rounded-xl border border-dark-200 bg-ivory-50 text-dark-800 placeholder-dark-300 text-sm transition-all duration-200 focus:border-gold-500 focus:ring-2 focus:ring-gold-500/20 focus:outline-none resize-none"></textarea>
            </div>

            <button type="submit" class="btn-primary w-full" data-cta="contact-form-submit">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Enviar por WhatsApp
            </button>
          </form>
        </div>
      </div>

      <!-- Contact Info + Schedule -->
      <div class="lg:col-span-2 reveal-right flex flex-col gap-4">

        <!-- WhatsApp destacado -->
        <a
          href={`https://wa.me/${site.contact.whatsappNumber}?text=${site.wa.agendarCita}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 p-5 bg-dark-900 rounded-2xl group hover:-translate-y-0.5 transition-all duration-300"
        >
          <div class="w-12 h-12 rounded-xl bg-green-500/15 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-400" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <div class="flex-1">
            <p class="font-semibold text-white text-sm">WhatsApp</p>
            <p class="text-green-400 text-sm">{site.contact.phoneLocal}</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white/30 group-hover:text-white/60 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>

        <!-- Contact grid 2x2 -->
        <div class="grid grid-cols-2 gap-3">
          <a href={`tel:${site.contact.phoneE164}`}
            class="flex flex-col gap-2 p-4 bg-white border border-dark-100/60 rounded-xl hover:border-gold-400/50 hover:-translate-y-0.5 transition-all duration-200 group">
            <div class="w-9 h-9 rounded-lg bg-gold-50 flex items-center justify-center group-hover:bg-gold-500 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gold-500 group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-dark-400 uppercase tracking-wider">Teléfono</p>
              <p class="text-dark-800 text-sm font-medium mt-0.5">{site.contact.phoneLocal}</p>
            </div>
          </a>

          <a href={`mailto:${site.contact.email}`}
            class="flex flex-col gap-2 p-4 bg-white border border-dark-100/60 rounded-xl hover:border-gold-400/50 hover:-translate-y-0.5 transition-all duration-200 group">
            <div class="w-9 h-9 rounded-lg bg-gold-50 flex items-center justify-center group-hover:bg-gold-500 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gold-500 group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-dark-400 uppercase tracking-wider">Email</p>
              <p class="text-dark-800 text-xs font-medium mt-0.5 break-all">{site.contact.email}</p>
            </div>
          </a>

          <div class="col-span-2 flex items-start gap-3 p-4 bg-white border border-dark-100/60 rounded-xl">
            <div class="w-9 h-9 rounded-lg bg-gold-50 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gold-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-dark-400 uppercase tracking-wider">Dirección</p>
              <p class="text-dark-800 text-sm font-medium mt-0.5">{site.contact.address.street}</p>
              <p class="text-dark-400 text-xs">{site.contact.address.colony}, {site.contact.address.city}, {site.contact.address.stateCode}</p>
            </div>
          </div>
        </div>

        <!-- Schedule -->
        <div class="bg-white border border-dark-100/60 rounded-xl p-4">
          <div class="flex items-center gap-2.5 mb-3">
            <div class="w-8 h-8 rounded-lg bg-gold-50 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gold-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <h4 class="font-heading font-bold text-dark-800 text-sm">Horario de Atención</h4>
          </div>
          <div class="space-y-1.5 text-sm">
            <div class="flex justify-between items-center py-1.5 border-b border-dark-50">
              <span class="text-dark-500 text-xs">{site.hours.weekdays.label}</span>
              <span class="font-semibold text-dark-800 text-xs">{site.hours.weekdays.morning} / {site.hours.weekdays.afternoon}</span>
            </div>
            <div class="flex justify-between items-center py-1.5 border-b border-dark-50">
              <span class="text-dark-500 text-xs">{site.hours.saturday.label}</span>
              <span class="text-dark-300 text-xs">{site.hours.saturday.status}</span>
            </div>
            <div class="flex justify-between items-center py-1.5">
              <span class="text-dark-500 text-xs">{site.hours.sunday.label}</span>
              <span class="text-dark-300 text-xs">{site.hours.sunday.status}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Full-width map -->
    <div class="rounded-2xl overflow-hidden border border-dark-100/60 shadow-sm reveal" style="height: 340px;">
      <iframe
        src={site.contact.mapsEmbedUrl}
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Ubicación de Dental Advance en Google Maps"
      ></iframe>
    </div>

  </div>
</section>

<script is:inline>
  const form = document.getElementById('contact-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const name    = (data.get('name')    || '').trim();
      const phone   = (data.get('phone')   || '').trim();
      const service = (data.get('service') || '').trim();
      const message = (data.get('message') || '').trim();

      let text = `Hola, me comunico desde el sitio web de Dental Advance.`;
      if (name)    text += `\n\n*Nombre:* ${name}`;
      if (phone)   text += `\n*Teléfono:* ${phone}`;
      if (service) text += `\n*Servicio:* ${service}`;
      if (message) text += `\n*Mensaje:* ${message}`;

      const waNumber = form.dataset.wa;
      window.open(`https://wa.me/${waNumber}?text=${encodeURIComponent(text)}`, '_blank');
      if (window.dataLayer) window.dataLayer.push({ event: 'contact_form_submit' });
    });
  }
</script>
