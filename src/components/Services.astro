---
import { site } from '../content/site.ts';
const services = [
  {
    title: 'Odontología General',
    description: 'Consultas, limpiezas profesionales, resinas y diagnóstico integral. Cuidamos tu salud bucal con revisiones completas y tratamientos preventivos adaptados a cada paciente.',
    tag: 'Prevención & Diagnóstico',
    featured: true,
    dark: true,
  },
  {
    title: 'Ortodoncia',
    description: 'Brackets metálicos, estéticos, de zafiro y alineadores invisibles para una sonrisa alineada.',
    tag: 'Corrección',
    featured: false,
    dark: false,
  },
  {
    title: 'Implantes Dentales',
    description: 'Titanio de alta calidad. Recupera la función y la estética de piezas perdidas de forma permanente.',
    tag: 'Rehabilitación',
    featured: false,
    dark: false,
    gold: true,
  },
  {
    title: 'Estética Dental',
    description: 'Blanqueamiento, carillas de porcelana y diseño de sonrisa. Transforma tu imagen.',
    tag: 'Cosmética',
    featured: false,
    dark: false,
  },
  {
    title: 'Endodoncia',
    description: 'Tratamientos de conductos con tecnología especializada. Salvamos tus dientes naturales.',
    tag: 'Terapia de raíz',
    featured: false,
    dark: false,
  },
  {
    title: 'Odontopediatría',
    description: 'Atención especial para niños en un ambiente amigable y de confianza. Cuidamos sus sonrisas.',
    tag: 'Niños',
    featured: false,
    dark: false,
    gold: true,
  },
  {
    title: 'Cirugía Oral',
    description: 'Extracciones y muelas del juicio con técnicas mínimamente invasivas.',
    tag: 'Procedimientos quirúrgicos',
    featured: false,
    dark: true,
  },
  {
    title: 'Periodoncia',
    description: 'Tratamiento de encías y limpiezas profundas. La base sana de tu sonrisa.',
    tag: 'Encías',
    featured: false,
    dark: false,
  },
];
---

<section id="servicios" class="py-20 sm:py-24 lg:py-28 bg-ivory-100">
  <div class="container-custom mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="max-w-2xl mb-14 reveal">
      <span class="section-label">Nuestros Servicios</span>
      <h2 class="text-4xl sm:text-5xl font-heading font-bold text-dark-900 leading-[1.08] mb-4">
        Cuidado dental <span class="gold-text">integral</span>
      </h2>
      <p class="text-lg text-dark-400 leading-relaxed">
        Tecnología avanzada y atención personalizada para cada etapa de tu salud bucal.
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-5">

      <!-- Card 1 — Featured, dark, col-span-2 -->
      <div class="sm:col-span-2 relative bg-dark-900 rounded-2xl p-8 lg:p-10 overflow-hidden reveal group">
        <!-- CSS decorative background -->
        <div class="absolute inset-0 opacity-[0.04]" aria-hidden="true"
          style="background-image: linear-gradient(to right, rgba(200,150,12,0.6) 1px, transparent 1px), linear-gradient(to bottom, rgba(200,150,12,0.6) 1px, transparent 1px); background-size: 40px 40px;">
        </div>
        <!-- Subtle gold glow -->
        <div class="absolute top-0 right-0 w-72 h-72 bg-gold-500/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-gold-500/5 rounded-full blur-2xl pointer-events-none"></div>
        <div class="relative">
          <span class="inline-block text-xs font-semibold text-gold-400/80 tracking-[0.18em] uppercase mb-4">{services[0].tag}</span>
          <h3 class="text-2xl lg:text-3xl font-heading font-bold text-white mb-3 leading-tight">{services[0].title}</h3>
          <p class="text-dark-300 text-base leading-relaxed max-w-lg">{services[0].description}</p>
          <div class="mt-8 flex items-center gap-2 text-gold-400 text-sm font-medium group-hover:gap-3 transition-all duration-300">
            <span>Consultar servicio</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Card 2 — Ortodoncia -->
      <div class="relative bg-ivory-50 border border-dark-100 rounded-2xl p-7 reveal group card-hover overflow-hidden">
        <span class="inline-block text-xs font-semibold text-gold-500/70 tracking-[0.16em] uppercase mb-3">{services[1].tag}</span>
        <h3 class="text-xl font-heading font-bold text-dark-900 mb-2">{services[1].title}</h3>
        <p class="text-sm text-dark-400 leading-relaxed">{services[1].description}</p>
        <div class="absolute bottom-0 left-7 right-7 h-px bg-gold-500 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 rounded-full"></div>
      </div>

      <!-- Card 3 — Implantes, gold-tinted -->
      <div class="relative bg-ivory-200/60 border border-gold-100/80 rounded-2xl p-7 reveal group card-hover overflow-hidden">
        <span class="inline-block text-xs font-semibold text-gold-600/70 tracking-[0.16em] uppercase mb-3">{services[2].tag}</span>
        <h3 class="text-xl font-heading font-bold text-dark-900 mb-2">{services[2].title}</h3>
        <p class="text-sm text-dark-500 leading-relaxed">{services[2].description}</p>
        <div class="absolute bottom-0 left-7 right-7 h-px bg-gold-500 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 rounded-full"></div>
      </div>

      <!-- Card 4 — Estética -->
      <div class="relative bg-ivory-50 border border-dark-100 rounded-2xl p-7 reveal group card-hover overflow-hidden">
        <span class="inline-block text-xs font-semibold text-gold-500/70 tracking-[0.16em] uppercase mb-3">{services[3].tag}</span>
        <h3 class="text-xl font-heading font-bold text-dark-900 mb-2">{services[3].title}</h3>
        <p class="text-sm text-dark-400 leading-relaxed">{services[3].description}</p>
        <div class="absolute bottom-0 left-7 right-7 h-px bg-gold-500 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 rounded-full"></div>
      </div>

      <!-- Card 5 — Endodoncia -->
      <div class="relative bg-ivory-50 border border-dark-100 rounded-2xl p-7 reveal group card-hover overflow-hidden">
        <span class="inline-block text-xs font-semibold text-gold-500/70 tracking-[0.16em] uppercase mb-3">{services[4].tag}</span>
        <h3 class="text-xl font-heading font-bold text-dark-900 mb-2">{services[4].title}</h3>
        <p class="text-sm text-dark-400 leading-relaxed">{services[4].description}</p>
        <div class="absolute bottom-0 left-7 right-7 h-px bg-gold-500 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 rounded-full"></div>
      </div>

      <!-- Card 6 — Odontopediatría, gold-tinted -->
      <div class="relative bg-ivory-200/60 border border-gold-100/80 rounded-2xl p-7 reveal group card-hover overflow-hidden">
        <span class="inline-block text-xs font-semibold text-gold-600/70 tracking-[0.16em] uppercase mb-3">{services[5].tag}</span>
        <h3 class="text-xl font-heading font-bold text-dark-900 mb-2">{services[5].title}</h3>
        <p class="text-sm text-dark-500 leading-relaxed">{services[5].description}</p>
        <div class="absolute bottom-0 left-7 right-7 h-px bg-gold-500 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 rounded-full"></div>
      </div>

      <!-- Card 7 — Cirugía, dark accent -->
      <div class="relative bg-dark-900 rounded-2xl p-7 reveal group card-hover overflow-hidden">
        <span class="inline-block text-xs font-semibold text-gold-400/70 tracking-[0.16em] uppercase mb-3">{services[6].tag}</span>
        <h3 class="text-xl font-heading font-bold text-white mb-2">{services[6].title}</h3>
        <p class="text-sm text-dark-300 leading-relaxed">{services[6].description}</p>
        <div class="absolute bottom-0 left-7 right-7 h-px bg-gold-500 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 rounded-full"></div>
      </div>

      <!-- Card 8 — Periodoncia -->
      <div class="relative bg-ivory-50 border border-dark-100 rounded-2xl p-7 reveal group card-hover overflow-hidden">
        <span class="inline-block text-xs font-semibold text-gold-500/70 tracking-[0.16em] uppercase mb-3">{services[7].tag}</span>
        <h3 class="text-xl font-heading font-bold text-dark-900 mb-2">{services[7].title}</h3>
        <p class="text-sm text-dark-400 leading-relaxed">{services[7].description}</p>
        <div class="absolute bottom-0 left-7 right-7 h-px bg-gold-500 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 rounded-full"></div>
      </div>

    </div>

    <!-- CTA -->
    <div class="mt-12 reveal">
      <a
        href={`https://wa.me/${site.contact.whatsappNumber}?text=${site.wa.servicios}`}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
        data-cta="services-consulta"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Consultar por WhatsApp
      </a>
    </div>

  </div>
</section>
